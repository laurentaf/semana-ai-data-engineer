# ShopAgent — Environment variables
# Semana AI Data Engineer 2026
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your real keys
#
# ShadowTraffic license (separate file):
#   cd gen && cp license.env.example license.env
#   # Get a free trial at https://shadowtraffic.io

# ──────────────────────────────────────────────
# Environment mode (local | cloud)
# Toggle this to switch all tools between Docker and cloud
# ──────────────────────────────────────────────
ENVIRONMENT=cloud

# ──────────────────────────────────────────────
# Postgres (Days 1-3, local Docker)
# ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shopagent
POSTGRES_USER=shopagent
POSTGRES_PASSWORD=shopagent

# ──────────────────────────────────────────────
# Qdrant (Days 2-3, local Docker)
# ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shopagent_reviews

# ──────────────────────────────────────────────
# Anthropic (Days 1-4, required)
# Get your key at https://console.anthropic.com/
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=http://localhost:8082

# ──────────────────────────────────────────────
# NVIDIA NIM Config (Day 3-4, free tier)
# Get your key at https://build.nvidia.com/
# ──────────────────────────────────────────────
NVIDIA_NIM_API_KEY=nvapi-your-key-here
NIM_LEDGER_MODEL=meta/llama-3.1-70b-instruct

# ──────────────────────────────────────────────
# OpenRouter (Day 4 cloud LLM — free tier)
# Get your key at https://openrouter.ai/
# ──────────────────────────────────────────────
OPEN_ROUTER_API_KEY=sk-or-your-key-here
LLM_MODEL=openrouter/owl-alpha

# ──────────────────────────────────────────────
# CrewAI LLM (Day 4)
# ──────────────────────────────────────────────
CREWAI_LLM=anthropic/claude-sonnet-4-20250514

# ──────────────────────────────────────────────
# DeepEval model (Day 4 evaluation)
# ──────────────────────────────────────────────
EVAL_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────
# Supabase Cloud (Day 4 migration — set ENVIRONMENT=cloud and fill these)
# ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your-anon-key-here
# Service role key (required for table creation + inserts bypassing RLS)
# Get from: Supabase Dashboard > Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_key_here
# Direct Postgres connection string for migration (overrides HOST/PORT above)
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
SUPABASE_TOKEN=your-supabase-token-here

# ──────────────────────────────────────────────
# Qdrant Cloud (Day 4 migration — set ENVIRONMENT=cloud and fill these)
# ──────────────────────────────────────────────
QDRANT_CLOUD_URL=https://xxxxx.cloud.qdrant.io:6333
QDRANT_CLOUD_API_KEY=your-qdrant-cloud-key

# ──────────────────────────────────────────────
# LangFuse (Day 4 observability — set ENVIRONMENT=cloud and fill these)
# ──────────────────────────────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-your-key
# LANGFUSE_PUBLIC_KEY=pk-lf-your-key
# LANGFUSE_HOST=https://cloud.langfuse.com
